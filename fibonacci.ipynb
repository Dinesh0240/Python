   "source": [
    "n = 10\n",
    "\n",
    "a=0\n",
    "b=1\n",
    "\n",
    "i=1\n",
    "while i<=n:\n",
    "    c=a+b\n",
    "    b=a\n",
    "    a=c\n",
    "    print(\"Fibonacci Numbers:\",c)\n",
    "    i+=1"
   ]
