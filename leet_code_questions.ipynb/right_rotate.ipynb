   "source": [
    "l = [1,2,3,4,5]     #rotation of list to the right by k positions\n",
    "k = 2\n",
    "new = [0]*len(l)\n",
    "\n",
    "for i in range(len(l)):\n",
    "    print(\"position:\",k,\"element:\",l[i])\n",
    "    k = k%len(l)\n",
    "    new[(i+k)%len(l)]=l[i]\n",
    "    print(new)"
   ]
